{
    "name": "letwang/hookphp",
    "type": "project",
    "description": "HookPHP is a simple, flexible, community driven PHP 8.4+ framework, based on the best ideas of other frameworks, with a fresh start!",
    "keywords": ["HookPHP", "application", "website", "development", "framework", "PHP", "PHP8", "mvc", "orm", "form", "validation", "opensource"],
    "homepage": "https://github.com/letwang/HookPHP",
    "license": "MIT",
    "authors": [
        {
            "name": "Let Wang",
            "email": "498936940@qq.com"
        }
    ],
    "require": {
        "ext-yaf": "*",
        "ext-date": "*",
        "ext-filter": "*",
        "ext-json": "*",
        "ext-pdo": "*",
        "ext-pdo_mysql": "*",
        "alipaysdk/easysdk": "^2.2",
        "doctrine/dbal": "^4.2",
        "doctrine/migrations": "^3.8",
        "doctrine/orm": "^3.2",
        "dompdf/dompdf": "^2.0",
        "endroid/qr-code": "^5.1",
        "fakerphp/faker": "^1.23",
        "firebase/php-jwt": "^6.10",
        "geoip2/geoip2": "^3.0",
        "google/recaptcha": "^1.3",
        "guzzlehttp/guzzle": "^7.9",
        "intervention/image": "^3.8",
        "league/oauth2-server": "^9.1",
        "mobiledetect/mobiledetectlib": "^4.8",
        "monolog/monolog": "^3.8",
        "overtrue/easy-sms": "^3.0",
        "phpmailer/phpmailer": "^6.9",
        "phpoffice/phpspreadsheet": "^3.7",
        "phpoffice/phpword": "^1.2",
        "respect/validation": "^2.3",
        "spatie/browsershot": "^5.0",
        "spatie/image-optimizer": "^1.8",
        "symfony/cache": "^7.2",
        "symfony/console": "^7.2",
        "symfony/filesystem": "^7.1",
        "symfony/finder": "^7.2",
        "symfony/form": "^7.1",
        "symfony/security-bundle": "^7.1",
        "symfony/security-core": "^7.2",
        "symfony/security-csrf": "^7.2",
        "symfony/security-http": "^7.2",
        "symfony/translation": "^7.1",
        "symfony/twig-bridge": "^7.1",
        "symfony/twig-bundle": "^7.1",
        "symfony/validator": "^7.1",
        "w7corp/easywechat": "^6.16"
    },
    "suggest": {
        "php": "Recommended PHP version >=8.4 for optimal performance.",
        "ext-amqp": "Required for AMQP (Advanced Message Queuing Protocol) support.",
        "ext-apcu": "Recommended for APCu caching support.",
        "ext-bcmath": "Required for arbitrary precision mathematics.",
        "ext-ctype": "Required for character type checking.",
        "ext-curl": "Required for working with URL requests (cURL).",
        "ext-dom": "Required for XML DOM support.",
        "ext-ftp": "Required for FTP support.",
        "ext-fileinfo": "Required for file information detection.",
        "ext-gd": "Required for image processing.",
        "ext-xsl": "Required for XSLT support.",
        "ext-hash": "Required for hashing algorithms support.",
        "ext-iconv": "Required for character encoding conversion.",
        "ext-igbinary": "Recommended for faster serialization in some cases.",
        "ext-intl": "Required for internationalization support.",
        "ext-mbstring": "Required for multibyte string handling.",
        "ext-mongodb": "Required for MongoDB support.",
        "ext-msgpack": "Recommended for more efficient serialization in some cases.",
        "ext-openssl": "Required for SSL/TLS encryption support.",
        "ext-session": "Required for session management support.",
        "ext-simplexml": "Required for XML parsing.",
        "ext-spl": "Required for SPL (Standard PHP Library) support.",
        "ext-xhprof": "Recommended for profiling and performance measurement.",
        "ext-xml": "Required for general XML processing.",
        "ext-zend-opcache": "Required for opcode caching (performance boost).",
        "ext-zip": "Required for working with ZIP archives.",
        "ext-zlib": "Allow gzip compression of HTTP requests",
        "ext-exif": "If you run Image class tests",
        "ext-imagick": "If you use Image class ImageMagickHandler",
        "ext-libxml": "If you use TestResponse",
        "ext-redis": "Required for Redis caching support.",
        "ext-memcache": "If you use Cache class MemcachedHandler with Memcache",
        "ext-memcached": "If you use Cache class MemcachedHandler with Memcached"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
